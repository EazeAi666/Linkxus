    <!-- Firebase Module Script with YOUR CONFIG -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { 
            getAuth, 
            signInWithPopup, 
            GoogleAuthProvider, 
            GithubAuthProvider,
            signInWithEmailAndPassword,
            createUserWithEmailAndPassword,
            signInAnonymously,
            signOut,
            onAuthStateChanged,
            setPersistence,
            browserLocalPersistence
        } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { 
            getFirestore, 
            collection, 
            doc, 
            addDoc, 
            getDocs, 
            getDoc,
            query, 
            where, 
            orderBy, 
            limit,
            onSnapshot,
            updateDoc,
            deleteDoc,
            serverTimestamp,
            increment,
            arrayUnion,
            arrayRemove
        } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";
        import {
            getStorage,
            ref,
            uploadBytes,
            getDownloadURL
        } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-storage.js";

        // YOUR ACTUAL FIREBASE CONFIG - DO NOT SHARE THIS PUBLICLY
        const firebaseConfig = {
            apiKey: "AIzaSyD3G9egUWZdJ5ffdvhyYpfTahn-QehR4Q8",
            authDomain: "linkxus-news.firebaseapp.com",
            projectId: "linkxus-news",
            storageBucket: "linkxus-news.firebasestorage.app",
            messagingSenderId: "524106434570",
            appId: "1:524106434570:web:625950c97aac9278c737f3",
            measurementId: "G-KBR7DY66Y3"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const storage = getStorage(app);

        setPersistence(auth, browserLocalPersistence);

        window.firebaseApp = app;
        window.firebaseAuth = auth;
        window.firebaseDb = db;
        window.firebaseStorage = storage;
        window.firebaseFunctions = {
            collection, doc, addDoc, getDocs, getDoc, query, where, orderBy, limit,
            onSnapshot, updateDoc, deleteDoc, serverTimestamp, increment, arrayUnion, arrayRemove,
            ref, uploadBytes, getDownloadURL, signOut
        };

        const googleProvider = new GoogleAuthProvider();
        const githubProvider = new GithubAuthProvider();

        onAuthStateChanged(auth, (user) => {
            window.currentUser = user;
            updateAuthUI(user);
            if (user) {
                document.getElementById('firebaseStatus').classList.remove('opacity-0');
                loadUserData(user.uid);
            }
        });

        window.signInWithGoogle = async () => {
            try {
                const result = await signInWithPopup(auth, googleProvider);
                toggleAuthModal();
            } catch (error) {
                alert("Sign in failed: " + error.message);
            }
        };

        window.signInWithGithub = async () => {
            try {
                const result = await signInWithPopup(auth, githubProvider);
                toggleAuthModal();
            } catch (error) {
                alert("Sign in failed: " + error.message);
            }
        };

        window.signInWithEmail = async () => {
            const email = document.getElementById('emailInput').value;
            const password = document.getElementById('passwordInput').value;
            try {
                const result = await signInWithEmailAndPassword(auth, email, password);
                toggleAuthModal();
            } catch (error) {
                if (error.code === 'auth/user-not-found') {
                    try {
                        const newUser = await createUserWithEmailAndPassword(auth, email, password);
                        toggleAuthModal();
                    } catch (createError) {
                        alert("Error creating account: " + createError.message);
                    }
                } else {
                    alert("Sign in failed: " + error.message);
                }
            }
        };

        window.signInAnonymously = async () => {
            try {
                await signInAnonymously(auth);
                toggleAuthModal();
            } catch (error) {
                console.error("Anonymous sign in error:", error);
            }
        };

        window.signOutUser = async () => {
            try {
                await signOut(auth);
            } catch (error) {
                console.error("Sign out error:", error);
            }
        };

        window.createPost = async () => {
            const content = document.getElementById('postContent').value;
            if (!content.trim() || !window.currentUser) return;

            try {
                const postData = {
                    content: content,
                    authorId: window.currentUser.uid,
                    authorName: window.currentUser.displayName || 'Anonymous',
                    authorPhoto: window.currentUser.photoURL || null,
                    category: window.currentCategory || 'general',
                    createdAt: serverTimestamp(),
                    likes: 0,
                    comments: 0,
                    shares: 0,
                    likedBy: [],
                    imageUrl: window.pendingImageUrl || null
                };

                await addDoc(collection(db, 'posts'), postData);
                document.getElementById('postContent').value = '';
                window.pendingImageUrl = null;
            } catch (error) {
                alert("Failed to create post");
            }
        };

        window.loadPosts = (category = 'all') => {
            const postsQuery = category === 'all' 
                ? query(collection(db, 'posts'), orderBy('createdAt', 'desc'), limit(20))
                : query(collection(db, 'posts'), where('category', '==', category), orderBy('createdAt', 'desc'), limit(20));

            return onSnapshot(postsQuery, (snapshot) => {
                const posts = [];
                snapshot.forEach((doc) => {
                    posts.push({ id: doc.id, ...doc.data() });
                });
                renderPosts(posts);
            });
        };

        window.toggleLike = async (postId, btn) => {
            if (!window.currentUser) {
                toggleAuthModal();
                return;
            }

            const postRef = doc(db, 'posts', postId);
            const postDoc = await getDoc(postRef);
            
            if (postDoc.exists()) {
                const data = postDoc.data();
                const likedBy = data.likedBy || [];
                const userId = window.currentUser.uid;

                if (likedBy.includes(userId)) {
                    await updateDoc(postRef, {
                        likes: increment(-1),
                        likedBy: arrayRemove(userId)
                    });
                } else {
                    await updateDoc(postRef, {
                        likes: increment(1),
                        likedBy: arrayUnion(userId)
                    });
                }
            }
        };

        window.handleImageUpload = async (event) => {
            const file = event.target.files[0];
            if (!file || !window.currentUser) return;

            try {
                const storageRef = ref(storage, `posts/${window.currentUser.uid}/${Date.now()}_${file.name}`);
                const snapshot = await uploadBytes(storageRef, file);
                const downloadURL = await getDownloadURL(snapshot.ref);
                window.pendingImageUrl = downloadURL;
            } catch (error) {
                console.error("Upload error:", error);
            }
        };

        window.setupRealtimeListeners = () => {
            onSnapshot(collection(db, 'users'), (snapshot) => {
                document.getElementById('activeReaders').textContent = snapshot.size.toLocaleString();
            });
        };

        window.addEventListener('load', () => {
            if (window.loadPosts) {
                window.postsUnsubscribe = window.loadPosts('all');
                window.setupRealtimeListeners();
            }
        });
    </script>

