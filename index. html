                'university': 'Top study abroad updates: MIT maintains #1 QS ranking. Oxford and Cambridge lead with 42% and 38% international students. Application deadlines approaching for Fall 2025.'
            };
            
            const lower = input.toLowerCase();
            for (const [key, value] of Object.entries(responses)) {
                if (lower.includes(key)) return value;
            }
            
            return `I've analyzed your query about "${input}". Based on current data from Linkxus feeds: This topic relates to ongoing developments in tech/crypto/security. Would you like me to summarize specific news stories, analyze market sentiment, or provide deeper technical context?`;
        }

