        function toggleSWAL() {
            swalOpen = !swalOpen;
            const modal = document.getElementById('swalModal');
            const panel = document.getElementById('swalPanel');
            
            if (swalOpen) {
                modal.classList.remove('hidden');
                setTimeout(() => panel.classList.remove('translate-x-full'), 10);
                document.getElementById('swalInput').focus();
            } else {
                panel.classList.add('translate-x-full');
                setTimeout(() => modal.classList.add('hidden'), 300);
            }
        }

        function handleSWALInput(e) {
            if (e.key === 'Enter') sendSWALMessage();
        }

        function quickAsk(text) {
            document.getElementById('swalInput').value = text;
            sendSWALMessage();
        }

        function sendSWALMessage() {
            const input = document.getElementById('swalInput');
            const text = input.value.trim();
            if (!text) return;
            
            addSWALMessage(text, 'user');
            input.value = '';
            
            setTimeout(() => {
                const response = generateSWALResponse(text);
                addSWALMessage(response, 'ai');
            }, 1000);
        }

        function addSWALMessage(text, sender) {
            const chat = document.getElementById('swalChat');
            const div = document.createElement('div');
            div.className = 'flex gap-3 animate-float';
            
            if (sender === 'user') {
                div.innerHTML = `
                    <div class="flex-1"></div>
                    <div class="bg-brand-600 rounded-2xl rounded-tr-none p-3 text-sm text-white max-w-[85%]">${text}</div>
