                        <i class="fas fa-robot text-white text-xs"></i>
                    </div>
                    <div class="bg-dark-800/80 rounded-2xl rounded-tl-none p-3 text-sm text-gray-300 max-w-[85%] typing-cursor">${text}</div>
                `;
            }
            
            chat.appendChild(div);
            chat.scrollTop = chat.scrollHeight;
            
            if (sender === 'ai') {
                setTimeout(() => {
                    const cursor = div.querySelector('.typing-cursor');
                    if (cursor) cursor.classList.remove('typing-cursor');
                }, 2000);
            }
        }

        function generateSWALResponse(input) {
            const responses = {
                'bitcoin': 'Bitcoin is currently trading at $71,296, up 4.61% following the Iran ceasefire. Key resistance at $73,000. Morgan Stanley\'s new ETF with 0.14% fee is challenging BlackRock\'s dominance.',
                'crypto': 'Crypto markets are bullish today. BTC +4.61%, ETH +6.54%, XRP +4.48%. Major news: Standard Chartered acquiring Zodia custody, Pharos Network $1B valuation.',
                'microsoft': 'Microsoft is heavily investing in AI automation. Key developments: Copilot for Researcher with Institut Curie, Khan Academy partnership for AI teaching tools.',
