        function startLiveUpdates() {
            setInterval(() => {
                cryptoData.forEach(c => {
                    const change = (Math.random() - 0.5) * 0.5;
                    c.price = c.price * (1 + change / 100);
                    c.change += change;
                });
                renderCryptoPrices();
            }, 5000);
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                if (swalOpen) toggleSWAL();
                if (!document.getElementById('authModal').classList.contains('hidden')) toggleAuthModal();
            }
            if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                e.preventDefault();
                document.getElementById('swalInput').focus();
                if (!swalOpen) toggleSWAL();
            }
